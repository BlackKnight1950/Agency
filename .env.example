# ── Smartsheet ──────────────────────────────────────────────────────────────
# Your Smartsheet API access token.
# Generate at: https://app.smartsheet.com/b/home → Account → Personal Settings → API Access
# NEVER commit the real value — set this in Render's Environment Variables dashboard.
SMARTSHEET_TOKEN=your_smartsheet_token_here

# ── Server ───────────────────────────────────────────────────────────────────
# Port the Express server listens on (Render sets this automatically).
PORT=3000

# ── CORS (optional) ──────────────────────────────────────────────────────────
# Restrict API access to your Render domain once deployed, e.g.:
#   ALLOWED_ORIGIN=https://arc-review-app.onrender.com
# Leave as * during development.
ALLOWED_ORIGIN=*
